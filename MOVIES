### Components/PanoramaView.swift

```swift
import SwiftUI
import SceneKit

// 360 panorama renderer: a sphere with the image mapped to its INSIDE,
// camera at the center. Touch-drag to look around (allowsCameraControl).
struct PanoramaView: UIViewRepresentable {
    var imageName: String

    func makeUIView(context: Context) -> SCNView {
        let view = SCNView()
        view.scene = makeScene(imageName: imageName)
        view.allowsCameraControl = true          // drag to look around
        view.backgroundColor = .black
        view.isUserInteractionEnabled = true
        // tweak: limits the zoom-out so users can't break the sphere illusion
        view.defaultCameraController.maximumVerticalAngle = 80
        view.defaultCameraController.minimumVerticalAngle = -80
        return view
    }

    func updateUIView(_ view: SCNView, context: Context) {
        // swap the texture when the selected seat changes
        view.scene = makeScene(imageName: imageName)
    }

    private func makeScene(imageName: String) -> SCNScene {
        let scene = SCNScene()

        let sphere = SCNSphere(radius: 10)
        sphere.segmentCount = 96                  // tweak: higher = smoother sphere
        let mat = SCNMaterial()
        mat.diffuse.contents = UIImage(named: imageName)
        mat.isDoubleSided = true
        mat.cullMode = .front                     // render the INSIDE of the sphere
        sphere.firstMaterial = mat

        let node = SCNNode(geometry: sphere)
        // flip horizontally so the panorama isn't mirrored
        node.scale = SCNVector3(1, 1, -1)
        scene.rootNode.addChildNode(node)

        let cameraNode = SCNNode()
        cameraNode.camera = SCNCamera()
        cameraNode.position = SCNVector3(0, 0, 0) // camera sits at sphere center
        cameraNode.camera?.fieldOfView = 75       // tweak: starting zoom
        scene.rootNode.addChildNode(cameraNode)

        return scene
    }
}
```

### Pages/MovieMainPage.swift

```swift
import SwiftUI

struct MovieMainPage: View {
    @State private var selected: Viewpoint = Viewpoint.all[0]
    @State private var showBooking = false

    var body: some View {
        ZStack {
            PanoramaView(imageName: selected.imageName)
                .ignoresSafeArea()

            VStack {
                // top stats strip (hidden at the entrance, where stats are "—")
                if selected.id != "entrance" {
                    statsStrip
                        .padding(.top, 8)
                }
                Spacer()
                seatButtons
                bookButton
                    .padding(.bottom, 24)
            }
            .padding(.horizontal, 16)

            if showBooking {
                bookingOverlay
            }
        }
        .preferredColorScheme(.dark)
    }

    private var statsStrip: some View {
        HStack(spacing: 20) {
            stat(selected.distance, "distance")
            stat(selected.angle, "offset")
            stat(selected.fov, "screen")
        }
        .padding(.vertical, 8).padding(.horizontal, 16)
        .background(.ultraThinMaterial, in: Capsule())
    }

    private func stat(_ value: String, _ label: String) -> some View {
        VStack(spacing: 1) {
            Text(value).font(.system(size: 15, weight: .semibold))
            Text(label).font(.system(size: 9)).foregroundStyle(.secondary)
                .textCase(.uppercase)
        }
    }

    private var seatButtons: some View {
        HStack(spacing: 10) {
            ForEach(Viewpoint.all) { vp in
                Button {
                    withAnimation(.easeInOut(duration: 0.3)) { selected = vp }
                } label: {
                    Text(vp.label)
                        .font(.system(size: 13, weight: .medium))
                        .padding(.vertical, 10).padding(.horizontal, 14)
                        .frame(maxWidth: .infinity)
                        .background(selected.id == vp.id ? Color.orange : Color.white.opacity(0.12),
                                    in: RoundedRectangle(cornerRadius: 12))
                        .foregroundStyle(selected.id == vp.id ? .black : .white)
                }
            }
        }
        .padding(.bottom, 12)
    }

    private var bookButton: some View {
        Button {
            showBooking = true
        } label: {
            Text(selected.id == "entrance" ? "Pick a seat to book" : "Book \(selected.label)")
                .font(.system(size: 15, weight: .semibold))
                .frame(maxWidth: .infinity).padding(.vertical, 14)
                .background(Color.blue, in: RoundedRectangle(cornerRadius: 14))
                .foregroundStyle(.white)
        }
        .disabled(selected.id == "entrance")
        .opacity(selected.id == "entrance" ? 0.5 : 1)
    }

    private var bookingOverlay: some View {
        ZStack {
            Color.black.opacity(0.6).ignoresSafeArea()
                .onTapGesture { showBooking = false }
            VStack(spacing: 14) {
                Image(systemName: "checkmark.circle.fill")
                    .font(.system(size: 44)).foregroundStyle(.green)
                Text("Seat booked").font(.system(size: 20, weight: .semibold))
                Text("\(selected.label) · \(selected.distance) from screen")
                    .font(.system(size: 14)).foregroundStyle(.secondary)
                Button("Done") { showBooking = false }
                    .font(.system(size: 15, weight: .medium))
                    .padding(.vertical, 10).padding(.horizontal, 28)
                    .background(Color.white.opacity(0.15), in: Capsule())
            }
            .padding(28)
            .background(.ultraThinMaterial, in: RoundedRectangle(cornerRadius: 20))
            .padding(40)
        }
    }
}

